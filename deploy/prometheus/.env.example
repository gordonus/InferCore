# Copy to .env (gitignored). Values come from Grafana Cloud → your stack →
# "Send metrics" / Prometheus remote_write (URL, user id, API token or password).

GC_REMOTE_WRITE_URL=https://prometheus-prod-XX-REGION.grafana.net/api/prom/push
GC_REMOTE_WRITE_USER=123456
GC_REMOTE_WRITE_PASSWORD=your_grafana_cloud_metrics_token

# Only needed if you uncomment authorization in prometheus.template.yml for InferCore API key:
# INFERCORE_API_KEY=
